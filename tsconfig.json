{
	"compilerOptions": {
		"target": "ES2017",
		"lib": [
			"dom",
			"dom.iterable",
			"esnext"
		],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@shared/*": [
				"./src/6_shared/*"
			],
			"@entities/*": [
				"./src/5_entities/*"
			],
			"@features/*": [
				"./src/4_features/*"
			],
			"@pages/*": [
				"./src/2_pages/*"
			],
			"@widgets/*": [
				"./src/3_widgets/*"
			]
		},
		"types": [
			"./env.d.ts",
			"node"
		]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}